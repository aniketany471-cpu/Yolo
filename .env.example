# ── Telegram (required) ────────────────────────────────────────────────────────
  # Get these from https://my.telegram.org → API development tools
  TELEGRAM_API_ID=123456
  TELEGRAM_API_HASH=your_api_hash_here

  # Your account's string session — generate via the dashboard Settings page
  TELEGRAM_STRING_SESSION=your_string_session_here

  # ── App security (required) ─────────────────────────────────────────────────────
  SESSION_SECRET=change_me_to_a_long_random_string

  # ── AI providers (optional — configure via dashboard AI Settings) ───────────────
  BLUESMINDS_API_KEY=sk-...
  GEMINI_API_KEY=your_gemini_key_here
  GROQ_API_KEY=your_groq_key_here
  OPENROUTER_API_KEY=your_openrouter_key_here
  